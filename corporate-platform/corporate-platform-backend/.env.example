NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Development startup seed (runs on backend boot when NODE_ENV != production)
DEV_SEED_ENABLED=true
DEV_SEED_EMAIL=admin@acme.com
DEV_SEED_PASSWORD=Demo123!
DEV_SEED_FIRST_NAME=Admin
DEV_SEED_LAST_NAME=User
DEV_SEED_ROLE=admin
DEV_SEED_COMPANY_ID=seed-dev-company
DEV_SEED_COMPANY_NAME=Acme Corp
DEV_SEED_RESET_PASSWORD=true

DATABASE_URL=postgresql://username:password@localhost:5432/db
DB_POOL_SIZE=10

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=corporate-platform-backend
KAFKA_SSL_ENABLED=false
KAFKA_RETRY_INITIAL=300
KAFKA_RETRY_MAX=5
KAFKA_FORCE_LOCAL=false

JWT_SECRET=dev-jwt-secret
JWT_EXPIRY=15m

STELLAR_NETWORK=testnet
HORIZON_URL=
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org:443
RETIREMENT_TRACKER_CONTRACT_ID=CCDCE6N7Q27TZW6Z6W3DPDCNOGHWFSOQUQPSRRZIY7AEHNOYZMNFDFVU
CARBON_ASSET_CONTRACT_ID=CAW7LUESK5RWH75W7IL64HYREFM5CPSFASBVVPVO2XOBC6AKHW4WJ6TM

# Webhook Configuration
WEBHOOK_BASE_URL=https://api.carbonscribe.com/webhooks
WEBHOOK_RETRY_MAX_ATTEMPTS=5
WEBHOOK_RETRY_DELAY_MS=5000
WEBHOOK_RETRY_BACKOFF_MULTIPLIER=2

# Certificate Anchoring Dead-Letter / Recovery (#400)
CERT_ANCHOR_RETRY_ENABLED=true
CERT_ANCHOR_RETRY_MAX_ATTEMPTS=5
CERT_ANCHOR_RETRY_BASE_DELAY_MS=60000
CERT_ANCHOR_RETRY_BACKOFF_MULTIPLIER=2
CERT_ANCHOR_RETRY_MAX_DELAY_MS=3600000
CERT_ANCHOR_ALERT_THRESHOLD=10
# CERT_ANCHOR_ALERT_WEBHOOK_URL=https://hooks.example.com/cert-anchor-alerts

# Horizon Event Stream
HORIZON_EVENT_RETRY_INTERVAL_MS=30000
HORIZON_CURSOR_STORAGE=redis

# Soroban Event Polling
SOROBAN_POLL_INTERVAL_MS=10000
# Leave blank to auto-bootstrap from the current ledger head at startup.
# Set to a specific recent ledger sequence number to resume from a known point.
SOROBAN_START_LEDGER=

# Multi-tenant configuration
TENANT_BASE_DOMAIN=platform.com
TENANT_SYSTEM_BYPASS_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Audit Hash Anchoring — Retirement Tracker (Soroban)
# ─────────────────────────────────────────────────────────────────────────────

# Contract ID for the RetirementTracker Soroban contract.
# Defaults to the value in contract.interface.ts if not set.
RETIREMENT_TRACKER_CONTRACT_ID=CCDCE6N7Q27TZW6Z6W3DPDCNOGHWFSOQUQPSRRZIY7AEHNOYZMNFDFVU

# Stellar secret key for PRODUCTION on-chain invocations.
# When set, SorobanService will sign and submit real transactions.
# Leave blank in development to fall back to simulation mode (no real tx submitted).
STELLAR_SECRET_KEY=

# Soroban RPC endpoint (already used by SorobanService; repeated here for clarity).
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org:443

# Generic audit blockchain anchor toggle (existing flag, kept for backwards-compat).
AUDIT_STELLAR_ANCHOR_ENABLED=false

# Rate limiting for audit hash endpoints (per tenant / IP).
# Max requests allowed within the rolling window.
AUDIT_ANCHOR_RATE_LIMIT_MAX=30
# Window size in milliseconds.
AUDIT_ANCHOR_RATE_LIMIT_WINDOW_MS=60000


# Pinata IPFS Configuration
# Required credentials for production decentralized storage. Mock configurations have been removed.
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here
PINATA_JWT=your_pinata_jwt_bearer_token_here

# Optional overrides
# PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/
# PINATA_TIMEOUT_MS=20000

# Pinata upload retry configuration
# PINATA_RETRY_MAX_ATTEMPTS=3
# PINATA_RETRY_INITIAL_DELAY_MS=1000
# PINATA_RETRY_MAX_DELAY_MS=30000
# PINATA_RETRY_BACKOFF_MULTIPLIER=2

# Pinata pin verification configuration
# Number of times to retry gateway retrieval check after upload (default: 3)
# PINATA_VERIFY_RETRY_ATTEMPTS=3
# Delay in ms between verification retry attempts (default: 1000)
# PINATA_VERIFY_RETRY_DELAY_MS=1000
# Timeout in ms for each verification attempt; falls back to PINATA_TIMEOUT_MS (default: 10000)
# PINATA_VERIFY_TIMEOUT_MS=10000
